# -----------------------------------------------------------------------
# WaterSmart MQTT Scraper – environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# -----------------------------------------------------------------------

# --- WaterSmart site ---
WATERSMART_URL=https://mercerislandwa.watersmart.com
ACCOUNT_NUMBER=00202650003

# --- Authentication: Option A – session cookies (recommended) ---
# Copy from browser DevTools → Network tab → any request to the site → Cookie header
PHPSESSID=
SESSION_COOKIE=
# The cookie name is the long hex string. Default is the Mercer Island one:
SESSION_COOKIE_NAME=a64b84d4419675c8425cb15c2f5fda28

# --- Authentication: Option B – username / password ---
# Leave blank if using cookies above.
WATERSMART_USERNAME=
WATERSMART_PASSWORD=

# --- MQTT broker ---
MQTT_BROKER=192.168.1.x
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
# Base topic — sensors publish to {MQTT_TOPIC_PREFIX}/latest and {MQTT_TOPIC_PREFIX}/hourly
MQTT_TOPIC_PREFIX=watersmart
MQTT_CLIENT_ID=watersmart-scraper
# Set to "true" to enable TLS (strongly recommended when MQTT_USERNAME is set)
MQTT_TLS=false
# Set to "true" ONLY for self-signed broker certs in dev/local environments.
# WARNING: disables broker certificate verification — never use in production.
MQTT_TLS_INSECURE=false

# --- Home Assistant ---
# Display name for the device in HA
HA_DEVICE_NAME=Water Meter
# Unique identifier used for entity IDs and MQTT discovery topics
HA_DEVICE_ID=watersmart_meter
# Must match the discovery prefix configured in HA (default: homeassistant)
HA_DISCOVERY_PREFIX=homeassistant

# --- Scraper behaviour ---
# How often to poll the API (minutes). Hourly is a safe default.
SCRAPE_INTERVAL_MINUTES=60

# --- Health server ---
HEALTH_PORT=8080
# Bind address for the health HTTP server.
# 0.0.0.0 = all interfaces (required for Kubernetes kubelet probes).
# 127.0.0.1 = loopback only (tighter security if probes aren't needed externally).
HEALTH_BIND=0.0.0.0
# How many seconds since the last successful scrape before /readyz fails.
# Defaults to 2× SCRAPE_INTERVAL_MINUTES (7200 for the default 60 min interval).
# HEALTH_SCRAPE_STALE_SECONDS=7200
